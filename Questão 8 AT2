programa {
  funcao inicio() {
    inteiro senha, tentativas
    
    tentativas = 0

    enquanto (tentativas < 3) {
      escreva("\nDigite a senha: ")
      leia(senha)

      se (senha == 2025) {
        escreva("\nAcesso Liberado")
        pare
      } senao {
        escreva("\nSenha incorreta")
        tentativas = tentativas + 1
      }
    }

    se (tentativas == 3) {
      escreva("\nAcesso Bloqueado")
    }
