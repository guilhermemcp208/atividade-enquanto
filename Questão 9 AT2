programa {
  funcao inicio() {
    inteiro opcao
    real saldo, deposito

    saldo = 1000.0
    opcao = 0

    enquanto (opcao != 4) {
      escreva("\n MENU DE ATENDIMENTO ")
      escreva("\n1 = Ver saldo")
      escreva("\n2 = Realizar depósito")
      escreva("\n3 = Atendimento em andamento")
      escreva("\n4 = Encerrar atendimento")
      escreva("\nEscolha uma opção: ")
      leia(opcao)

      escolha (opcao) {
        caso 1:
          escreva("\nSeu saldo é: R$", saldo)
          pare

        caso 2:
          escreva("\nDigite o valor do depósito: ")
          leia(deposito)

          saldo = saldo + deposito
          escreva("\nDepósito realizado com sucesso!")
          pare

        caso 3:
          escreva("\nAtendimento em andamento")
          pare

        caso 4:
          escreva("\nAtendimento encerrado.")
          pare

        caso contrario:
          escreva("\nOpção inválida!")
      }
